# ============================================================================
# autobot configuration
#
# HOW TO CHANGE A DEFAULT: delete the leading "#" on that line (uncomment it)
# and set the value. A commented-out line is ignored completely — autobot
# falls back to the built-in default in autobot/config.py instead.
#
# Copy this file to .env and fill in what you need.
# ============================================================================

# --- Notion --------------------------------------------------------------
# Internal integration secret used to read/update the projects database.
# 1. https://www.notion.so/profile/integrations -> New integration (internal)
# 2. Copy the secret.
# 3. Open the projects database in Notion -> ••• menu -> Connections -> add
#    the integration you just created.
#
# NOTE: if this folder lives inside an autoclaude checkout
# (autoclaude/workspaces/autobot-opencode), autobot automatically borrows
# NOTION_TOKEN / NOTION_DATABASE_ID from autoclaude's .env two levels up —
# in that case you can leave both unset here.
#NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxx

# ID of the projects database (default: the "Claude Projects" DB).
#NOTION_DATABASE_ID=10aefa04a0d14dc4add853782342b841

# --- What runs the projects -----------------------------------------------
# Default backend when neither --backend nor the Notion row's Backend column
# says otherwise: claude | opencode | custom
#AUTOBOT_BACKEND=opencode

# Default model. Leave unset to let the backend pick its own default.
#   claude:   opus | sonnet | haiku | fable | a full model id
#   opencode: provider/model — run `opencode models` for the list. Examples:
#             zai-coding-plan/glm-4.6          (Z.AI GLM coding plan)
#             openrouter/moonshotai/kimi-k2    (Kimi K2 via OpenRouter)
#             openrouter/minimax/minimax-m2    (MiniMax via OpenRouter)
#AUTOBOT_MODEL=zai-coding-plan/glm-4.6

# Effort / thinking level: default | low | medium | high | xhigh | max | ultracode
# claude gets it natively (--effort); other backends get it as an instruction
# prepended to the prompt.
#AUTOBOT_EFFORT=xhigh

# Extra arguments appended to `opencode run` (e.g. an agent profile).
#AUTOBOT_OPENCODE_ARGS=--agent build

# Command template for the "custom" backend — any CLI (OpenClaw, aider,
# codex, ...). Placeholders: {prompt_file} {prompt} {stdin} {model} {effort}
# {workspace}. {stdin} as a standalone token pipes the prompt to stdin.
# Examples:
#AUTOBOT_CUSTOM_CMD=aider --yes-always --message-file {prompt_file}
#AUTOBOT_CUSTOM_CMD=codex exec --full-auto {prompt}

# --- Behavior ---------------------------------------------------------------
# Claude Code only: --permission-mode. bypassPermissions = fully unattended.
#AUTOBOT_PERMISSION_MODE=bypassPermissions

# Max minutes a single project run may take before it's killed and marked ❌.
#AUTOBOT_TIMEOUT_MIN=120

# --watch: minutes between Notion checks while the queue is empty.
#AUTOBOT_POLL_MIN=30

# --watch: minutes to wait before retrying after a usage/rate limit whose
# reset time couldn't be parsed (when it can be, autobot sleeps until then).
#AUTOBOT_LIMIT_RETRY_MIN=60

# --- Paths / binaries -------------------------------------------------------
# Where project code is written, one subfolder per project.
#AUTOBOT_WORKSPACES=C:\path\to\workspaces

# Only needed if auto-detection fails.
#CLAUDE_BIN=C:\Users\you\AppData\Roaming\Claude\claude-code\2.1.170\claude.exe
#OPENCODE_BIN=C:\Users\you\AppData\Roaming\npm\opencode.cmd

# --- Provider API keys (passed through to the agent process) ----------------
# Anything you set in this file is exported to the agent subprocess, so
# provider keys can live here too if you don't use `opencode auth login`:
#ZHIPUAI_API_KEY=...
#OPENROUTER_API_KEY=...
#MOONSHOT_API_KEY=...
#MINIMAX_API_KEY=...
